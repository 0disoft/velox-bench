{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/startup-benchmark/v3.json",
  "title": "Actutum startup benchmark v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "framework", "frameworkRevision", "evidenceLevel", "sample", "fixtureSha256", "outcome", "startedAtUtc", "finishedAtUtc", "environment", "measurement", "failure"],
  "properties": {
    "schemaVersion": { "const": "actutum.startup-benchmark/v3" },
    "suite": { "const": "actutum-startup" },
    "framework": { "const": "actutum" },
    "frameworkRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "evidenceLevel": { "enum": ["hosted-pinned-source", "local-unverified-release"] },
    "sample": { "type": "integer", "minimum": 0, "maximum": 9 },
    "fixtureSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outcome": { "enum": ["success", "failure", "timeout"] },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "runnerImageVersion", "windowsVersion", "cpuModel", "logicalProcessors", "memoryBytes", "bunVersion", "repositoryCommit", "runId", "runAttempt", "webView2Version"],
      "properties": {
        "runner": { "const": "windows-2025" },
        "runnerImageVersion": { "type": "string", "minLength": 1 },
        "windowsVersion": { "type": "string", "minLength": 1 },
        "cpuModel": { "type": "string", "minLength": 1 },
        "logicalProcessors": { "type": "integer", "minimum": 1 },
        "memoryBytes": { "type": "integer", "minimum": 1 },
        "bunVersion": { "const": "1.3.14" },
        "repositoryCommit": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "runAttempt": { "type": "string", "minLength": 1 },
        "webView2Version": { "type": "string", "minLength": 1 }
      }
    },
    "measurement": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyBoundary", "warmupCount", "fresh", "warm"],
          "properties": {
            "readyBoundary": { "const": "process-start-to-domcontentloaded-plus-two-animation-frames" },
            "warmupCount": { "const": 5 },
            "fresh": { "$ref": "#/$defs/launch" },
            "warm": { "$ref": "#/$defs/launch" }
          }
        },
        { "type": "null" }
      ]
    },
    "failure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase", "code"],
          "properties": {
            "phase": { "type": "string", "minLength": 1 },
            "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
          }
        },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "elapsedMs"],
      "properties": {
        "name": {
          "enum": [
            "host-entry",
            "config-loaded",
            "runtime-open-started",
            "window-create-started",
            "environment-create-started",
            "environment-created",
            "controller-created",
            "webview-created",
            "navigation-dispatched",
            "runtime-opened",
            "dom-2raf"
          ]
        },
        "elapsedMs": { "type": "number", "minimum": 0 }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "clock", "phases"],
      "properties": {
        "schemaVersion": { "const": "actutum.host-startup-timeline/v1" },
        "clock": { "const": "time-since-host-entry-monotonic" },
        "phases": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "prefixItems": [
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "host-entry" }, "elapsedMs": { "const": 0 } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "config-loaded" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "runtime-open-started" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "window-create-started" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "environment-create-started" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "environment-created" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "controller-created" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "webview-created" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "navigation-dispatched" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "runtime-opened" } } }] },
            { "allOf": [{ "$ref": "#/$defs/phase" }, { "properties": { "name": { "const": "dom-2raf" } } }] }
          ],
          "items": false
        }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readyMs", "hostExitAfterReadyMs", "browserExitAfterHostMs", "profileReleaseAfterHostMs", "browserProcessId", "hostTimeline"],
      "properties": {
        "readyMs": { "type": "number", "minimum": 0 },
        "hostExitAfterReadyMs": { "type": "number", "minimum": 0 },
        "browserExitAfterHostMs": { "type": "number", "minimum": 0 },
        "profileReleaseAfterHostMs": { "type": "number", "minimum": 0 },
        "browserProcessId": { "type": "integer", "minimum": 1 },
        "hostTimeline": { "$ref": "#/$defs/timeline" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": { "properties": { "measurement": { "type": "object" }, "failure": { "type": "null" } } },
      "else": { "properties": { "measurement": { "type": "null" }, "failure": { "type": "object" } } }
    }
  ]
}
