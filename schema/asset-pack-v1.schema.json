{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/bench/asset-pack-v1.schema.json",
  "title": "Velox deterministic asset-pack fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "algorithm", "seed", "layout"],
  "properties": {
    "schemaVersion": { "const": "velox.asset-pack-fixture/v1" },
    "algorithm": { "const": "xorshift32-v1" },
    "seed": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "directories", "fileCount", "totalBytes", "extension"],
      "properties": {
        "root": { "const": "assets" },
        "directories": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "fileCount": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "totalBytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "extension": { "const": ".bin" }
      }
    }
  }
}
