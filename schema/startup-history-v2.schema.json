{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/startup-history/v2.json",
  "title": "Actutum startup benchmark history v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "outcome", "generatedAtUtc", "points", "series", "collectionIssues"],
  "properties": {
    "schemaVersion": { "const": "actutum.startup-history/v2" },
    "suite": { "const": "actutum-startup" },
    "outcome": { "enum": ["complete", "partial"] },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "points": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["runId", "runAttempt", "benchmarkCommit", "createdAtUtc", "summary"],
        "properties": {
          "runId": { "type": "string", "pattern": "^[0-9]+$" },
          "runAttempt": { "type": "integer", "minimum": 1 },
          "benchmarkCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "createdAtUtc": { "type": "string", "format": "date-time" },
          "summary": { "$ref": "https://schemas.actutum.invalid/startup-summary/v2.json" }
        }
      }
    },
    "series": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["environmentKey", "runIds"],
        "properties": {
          "environmentKey": { "type": "string", "minLength": 1 },
          "runIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[0-9]+$" }
          }
        }
      }
    },
    "collectionIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["runId", "code"],
        "properties": {
          "runId": { "type": "string", "pattern": "^[0-9]+$" },
          "code": { "enum": ["ARTIFACT_MISSING", "ARTIFACT_DOWNLOAD_FAILED", "SUMMARY_INVALID"] }
        }
      }
    }
  }
}
