{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/asset-transport-delay-summary/v2.json",
  "title": "Actutum asset transport relaunch delay summary v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "expectedPerCell", "observed", "publishable", "environmentCount", "experimentClassification", "rows"],
  "properties": {
    "schemaVersion": { "const": "actutum.asset-transport-delay-summary/v2" },
    "suite": { "const": "asset-transport-relaunch-delay-sweep" },
    "expectedPerCell": { "enum": [1, 3, 10] },
    "observed": { "type": "integer", "minimum": 0, "maximum": 200 },
    "publishable": { "type": "boolean" },
    "environmentCount": { "type": "integer", "minimum": 0 },
    "experimentClassification": { "enum": ["recovery-boundary-observed", "no-delay-observed", "not-recovered-within-range", "insufficient-evidence"] },
    "rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["transport", "revision", "recoveryClassification", "maximumDelayWithTailMs", "cleanFromDelayMs", "cells"],
        "properties": {
          "transport": { "enum": ["actutum", "fork-file-url", "fork-virtual-host", "fork-web-resource"] },
          "revision": { "type": "string", "minLength": 1 },
          "recoveryClassification": { "enum": ["recovers-within-range", "no-delay-observed", "not-recovered-within-range", "insufficient-evidence"] },
          "maximumDelayWithTailMs": { "oneOf": [{ "enum": [0, 100, 250, 500, 1000] }, { "type": "null" }] },
          "cleanFromDelayMs": { "oneOf": [{ "enum": [0, 100, 250, 500, 1000] }, { "type": "null" }] },
          "cells": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": { "$ref": "#/$defs/cell" }
          }
        }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minMs", "p50Ms", "p95Ms", "maxMs"],
      "properties": {
        "minMs": { "type": "number" },
        "p50Ms": { "type": "number" },
        "p95Ms": { "type": "number" },
        "maxMs": { "type": "number" }
      }
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestedDelayMs", "observed", "successful", "failed", "timedOut", "pairedDelaySamples", "pairedDelayRate", "firstReady", "relaunchedReady", "relaunchedMinusFirst", "actualStartGap"],
      "properties": {
        "requestedDelayMs": { "enum": [0, 100, 250, 500, 1000] },
        "observed": { "type": "integer", "minimum": 0, "maximum": 10 },
        "successful": { "type": "integer", "minimum": 0, "maximum": 10 },
        "failed": { "type": "integer", "minimum": 0, "maximum": 10 },
        "timedOut": { "type": "integer", "minimum": 0, "maximum": 10 },
        "pairedDelaySamples": { "type": "integer", "minimum": 0, "maximum": 10 },
        "pairedDelayRate": { "oneOf": [{ "type": "number", "minimum": 0, "maximum": 1 }, { "type": "null" }] },
        "firstReady": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
        "relaunchedReady": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
        "relaunchedMinusFirst": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
        "actualStartGap": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] }
      }
    }
  }
}
