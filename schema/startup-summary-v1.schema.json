{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/startup-summary/v1.json",
  "title": "Velox startup benchmark summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "framework", "expected", "observed", "missing", "successful", "failed", "timedOut", "publishable", "evidenceLevels", "environmentGroups", "fresh", "warm"],
  "properties": {
    "schemaVersion": { "const": "velox.startup-summary/v1" },
    "suite": { "const": "velox-startup" },
    "framework": { "const": "velox" },
    "expected": { "enum": [1, 3, 10] },
    "observed": { "type": "integer", "minimum": 0 },
    "missing": { "type": "integer", "minimum": 0 },
    "successful": { "type": "integer", "minimum": 0 },
    "failed": { "type": "integer", "minimum": 0 },
    "timedOut": { "type": "integer", "minimum": 0 },
    "publishable": { "type": "boolean" },
    "evidenceLevels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["hosted-pinned-release", "hosted-pinned-source", "local-unverified-release"] }
    },
    "environmentGroups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "samples"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "samples": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "fresh": { "oneOf": [{ "$ref": "#/$defs/statistics" }, { "type": "null" }] },
    "warm": { "oneOf": [{ "$ref": "#/$defs/statistics" }, { "type": "null" }] }
  },
  "$defs": {
    "statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minMs", "p50Ms", "p95Ms", "maxMs"],
      "properties": {
        "minMs": { "type": "number", "minimum": 0 },
        "p50Ms": { "type": "number", "minimum": 0 },
        "p95Ms": { "type": "number", "minimum": 0 },
        "maxMs": { "type": "number", "minimum": 0 }
      }
    }
  }
}
