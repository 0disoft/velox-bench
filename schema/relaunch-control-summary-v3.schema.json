{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/relaunch-control-summary/v3.json",
  "title": "Actutum cross-host immediate relaunch summary v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "expectedPerFramework", "observed", "publishable", "platformClassification", "rows"],
  "properties": {
    "schemaVersion": { "const": "actutum.relaunch-control-summary/v3" },
    "suite": { "const": "same-profile-immediate-relaunch" },
    "expectedPerFramework": { "enum": [1, 3, 10] },
    "observed": { "type": "integer", "minimum": 0, "maximum": 40 },
    "publishable": { "type": "boolean" },
    "platformClassification": { "enum": ["actutum-specific-delay", "shared-immediate-relaunch-delay", "webview2-host-delay", "control-specific-delay", "mixed-or-not-observed"] },
    "rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["framework", "revision", "profileControl", "observed", "successful", "failed", "timedOut", "delayClassification", "pairedDelaySamples", "pairedDelayRate", "firstReady", "immediateReady", "immediateMinusFirst"],
        "properties": {
          "framework": { "enum": ["actutum", "webview2-control", "wails", "neutralino"] },
          "revision": { "type": "string", "minLength": 1 },
          "profileControl": { "type": "string", "minLength": 1 },
          "observed": { "type": "integer", "minimum": 0, "maximum": 10 },
          "successful": { "type": "integer", "minimum": 0, "maximum": 10 },
          "failed": { "type": "integer", "minimum": 0, "maximum": 10 },
          "timedOut": { "type": "integer", "minimum": 0, "maximum": 10 },
          "delayClassification": { "enum": ["observed", "not-observed", "insufficient-evidence"] },
          "pairedDelaySamples": { "type": "integer", "minimum": 0, "maximum": 10 },
          "pairedDelayRate": { "oneOf": [{ "type": "number", "minimum": 0, "maximum": 1 }, { "type": "null" }] },
          "firstReady": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
          "immediateReady": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
          "immediateMinusFirst": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] }
        }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minMs", "p50Ms", "p95Ms", "maxMs"],
      "properties": {
        "minMs": { "type": "number" },
        "p50Ms": { "type": "number" },
        "p95Ms": { "type": "number" },
        "maxMs": { "type": "number" }
      }
    }
  }
}
