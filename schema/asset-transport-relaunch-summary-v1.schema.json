{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/asset-transport-relaunch-summary/v1.json",
  "title": "Velox asset transport immediate relaunch summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "expectedPerTransport", "observed", "publishable", "transportClassification", "rows"],
  "properties": {
    "schemaVersion": { "const": "velox.asset-transport-relaunch-summary/v1" },
    "suite": { "const": "asset-transport-immediate-relaunch" },
    "expectedPerTransport": { "enum": [1, 3, 10] },
    "observed": { "type": "integer", "minimum": 0, "maximum": 40 },
    "publishable": { "type": "boolean" },
    "transportClassification": { "enum": ["virtual-host-mapping-delay", "velox-only-delay", "virtual-host-control-delay", "web-resource-delay", "shared-delay", "not-observed", "insufficient-evidence", "mixed-delay"] },
    "rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["transport", "revision", "observed", "successful", "failed", "timedOut", "delayClassification", "pairedDelaySamples", "pairedDelayRate", "firstReady", "immediateReady", "immediateMinusFirst"],
        "properties": {
          "transport": { "enum": ["velox", "fork-file-url", "fork-virtual-host", "fork-web-resource"] },
          "revision": { "type": "string", "minLength": 1 },
          "observed": { "type": "integer", "minimum": 0, "maximum": 10 },
          "successful": { "type": "integer", "minimum": 0, "maximum": 10 },
          "failed": { "type": "integer", "minimum": 0, "maximum": 10 },
          "timedOut": { "type": "integer", "minimum": 0, "maximum": 10 },
          "delayClassification": { "enum": ["observed", "not-observed", "insufficient-evidence"] },
          "pairedDelaySamples": { "type": "integer", "minimum": 0, "maximum": 10 },
          "pairedDelayRate": { "oneOf": [{ "type": "number", "minimum": 0, "maximum": 1 }, { "type": "null" }] },
          "firstReady": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
          "immediateReady": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] },
          "immediateMinusFirst": { "oneOf": [{ "$ref": "#/$defs/metric" }, { "type": "null" }] }
        }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minMs", "p50Ms", "p95Ms", "maxMs"],
      "properties": {
        "minMs": { "type": "number" },
        "p50Ms": { "type": "number" },
        "p95Ms": { "type": "number" },
        "maxMs": { "type": "number" }
      }
    }
  }
}
