{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/bench-result/v1.json",
  "title": "Velox cross-framework benchmark result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "framework", "frameworkRevision", "sample", "fixtureSha256", "outcome", "startedAtUtc", "finishedAtUtc", "environment", "measurement", "failure"],
  "properties": {
    "schemaVersion": { "const": "velox.bench-result/v1" },
    "suite": { "const": "zero-cache" },
    "framework": { "enum": ["velox", "wails", "neutralino", "tauri"] },
    "frameworkRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sample": { "type": "integer", "minimum": 0, "maximum": 9 },
    "fixtureSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outcome": { "enum": ["success", "failure", "timeout"] },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "runnerImageVersion", "os", "architecture", "windowsVersion", "cpuModel", "logicalProcessors", "memoryBytes", "bunVersion", "repositoryCommit", "runId", "runAttempt"],
      "properties": {
        "runner": { "const": "windows-2025" },
        "runnerImageVersion": { "type": "string", "minLength": 1 },
        "os": { "const": "windows" },
        "architecture": { "const": "amd64" },
        "windowsVersion": { "type": "string", "minLength": 1 },
        "cpuModel": { "type": "string", "minLength": 1 },
        "logicalProcessors": { "type": "integer", "minimum": 1 },
        "memoryBytes": { "type": "integer", "minimum": 1 },
        "bunVersion": { "const": "1.3.14" },
        "repositoryCommit": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "runAttempt": { "type": "string", "minLength": 1 }
      }
    },
    "measurement": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["endToEndMs", "frameworkSetupMs", "buildMs", "packageMs", "acquisitionWorkingSetBytes", "outputFiles", "outputBytes", "outputArchiveBytes", "outputArchiveSha256", "intermediateFiles", "intermediateBytes", "uploadedCacheBytes", "cacheEvidence"],
          "properties": {
            "endToEndMs": { "type": "number", "minimum": 0 },
            "frameworkSetupMs": { "type": "number", "minimum": 0 },
            "buildMs": { "type": "number", "minimum": 0 },
            "packageMs": { "type": "number", "minimum": 0 },
            "acquisitionWorkingSetBytes": { "type": "integer", "minimum": 0 },
            "outputFiles": { "type": "integer", "minimum": 1 },
            "outputBytes": { "type": "integer", "minimum": 1 },
            "outputArchiveBytes": { "type": "integer", "minimum": 1 },
            "outputArchiveSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "intermediateFiles": { "type": "integer", "minimum": 0 },
            "intermediateBytes": { "type": "integer", "minimum": 0 },
            "uploadedCacheBytes": { "const": 0 },
            "cacheEvidence": { "const": "workflow-source-audit" }
          }
        },
        { "type": "null" }
      ]
    },
    "failure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase", "code"],
          "properties": {
            "phase": { "type": "string", "minLength": 1 },
            "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
          }
        },
        { "type": "null" }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": { "properties": { "measurement": { "type": "object" }, "failure": { "type": "null" } } },
      "else": { "properties": { "measurement": { "type": "null" }, "failure": { "type": "object" } } }
    }
  ]
}
