{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/startup-benchmark/v1.json",
  "title": "Velox startup benchmark v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "framework", "frameworkRevision", "evidenceLevel", "sample", "fixtureSha256", "outcome", "startedAtUtc", "finishedAtUtc", "environment", "measurement", "failure"],
  "properties": {
    "schemaVersion": { "const": "velox.startup-benchmark/v1" },
    "suite": { "const": "velox-startup" },
    "framework": { "const": "velox" },
    "frameworkRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "evidenceLevel": { "enum": ["hosted-pinned-release", "hosted-pinned-source", "local-unverified-release"] },
    "sample": { "type": "integer", "minimum": 0, "maximum": 9 },
    "fixtureSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outcome": { "enum": ["success", "failure", "timeout"] },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "runnerImageVersion", "windowsVersion", "cpuModel", "logicalProcessors", "memoryBytes", "bunVersion", "repositoryCommit", "runId", "runAttempt", "webView2Version"],
      "properties": {
        "runner": { "const": "windows-2025" },
        "runnerImageVersion": { "type": "string", "minLength": 1 },
        "windowsVersion": { "type": "string", "minLength": 1 },
        "cpuModel": { "type": "string", "minLength": 1 },
        "logicalProcessors": { "type": "integer", "minimum": 1 },
        "memoryBytes": { "type": "integer", "minimum": 1 },
        "bunVersion": { "const": "1.3.14" },
        "repositoryCommit": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "runAttempt": { "type": "string", "minLength": 1 },
        "webView2Version": { "type": "string", "minLength": 1 }
      }
    },
    "measurement": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyBoundary", "warmupCount", "fresh", "warm"],
          "properties": {
            "readyBoundary": { "const": "process-start-to-domcontentloaded-plus-two-animation-frames" },
            "warmupCount": { "const": 5 },
            "fresh": { "$ref": "#/$defs/launch" },
            "warm": { "$ref": "#/$defs/launch" }
          }
        },
        { "type": "null" }
      ]
    },
    "failure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase", "code"],
          "properties": {
            "phase": { "type": "string", "minLength": 1 },
            "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
          }
        },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readyMs", "hostExitAfterReadyMs", "browserExitAfterHostMs", "profileReleaseAfterHostMs", "browserProcessId"],
      "properties": {
        "readyMs": { "type": "number", "minimum": 0 },
        "hostExitAfterReadyMs": { "type": "number", "minimum": 0 },
        "browserExitAfterHostMs": { "type": "number", "minimum": 0 },
        "profileReleaseAfterHostMs": { "type": "number", "minimum": 0 },
        "browserProcessId": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": { "properties": { "measurement": { "type": "object" }, "failure": { "type": "null" } } },
      "else": { "properties": { "measurement": { "type": "null" }, "failure": { "type": "object" } } }
    }
  ]
}
