{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0disoft.dev/velox/recommended-cache-summary-v1.schema.json",
  "title": "Velox recommended-cache summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "expectedSamples", "expectedFrameworks", "evidenceComplete", "comparativeClaimAllowed", "rows"],
  "properties": {
    "schemaVersion": { "const": "velox.recommended-cache-summary/v1" },
    "suite": { "const": "recommended-cache" },
    "expectedSamples": { "enum": [1, 3] },
    "expectedFrameworks": { "type": "array", "items": { "enum": ["velox", "wails", "neutralino", "tauri"] }, "minItems": 1, "uniqueItems": true },
    "evidenceComplete": { "type": "boolean" },
    "comparativeClaimAllowed": { "const": false },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["framework", "cachePolicy", "successfulPrimeSamples", "successfulWarmSamples", "failureCount", "missingCount", "archiveBytesP50", "uploadedCacheBytesTotal", "primeEndToEndP50Ms", "warmEndToEndP50Ms", "warmRestoreP50Ms", "warmBuildP50Ms"],
        "properties": {
          "framework": { "enum": ["velox", "wails", "neutralino", "tauri"] },
          "cachePolicy": { "enum": ["none", "go-module-build", "npm-download", "cargo-registry-target"] },
          "successfulPrimeSamples": { "type": "integer", "minimum": 0 },
          "successfulWarmSamples": { "type": "integer", "minimum": 0 },
          "failureCount": { "type": "integer", "minimum": 0 },
          "missingCount": { "type": "integer", "minimum": 0 },
          "archiveBytesP50": { "type": ["number", "null"], "minimum": 0 },
          "uploadedCacheBytesTotal": { "type": "integer", "minimum": 0 },
          "primeEndToEndP50Ms": { "type": ["number", "null"], "minimum": 0 },
          "warmEndToEndP50Ms": { "type": ["number", "null"], "minimum": 0 },
          "warmRestoreP50Ms": { "type": ["number", "null"], "minimum": 0 },
          "warmBuildP50Ms": { "type": ["number", "null"], "minimum": 0 }
        }
      }
    }
  }
}
