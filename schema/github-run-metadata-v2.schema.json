{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/bench/github-run-metadata-v2.schema.json",
  "title": "Actutum normalized GitHub run metadata v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "capturedAtUtc", "run", "jobs", "artifacts"],
  "properties": {
    "schemaVersion": { "const": "actutum.github-run-metadata/v2" },
    "repository": { "const": "0disoft/actutum-bench" },
    "capturedAtUtc": { "type": "string", "format": "date-time" },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "attempt", "url", "workflowName", "event", "headSha", "status", "conclusion", "createdAtUtc", "startedAtUtc", "completedAtUtc"],
      "properties": {
        "id": { "type": "string", "pattern": "^[0-9]+$" },
        "attempt": { "type": "integer", "minimum": 1 },
        "url": { "type": "string", "format": "uri" },
        "workflowName": { "type": "string", "minLength": 1 },
        "event": { "type": "string", "minLength": 1 },
        "headSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "status": { "const": "completed" },
        "conclusion": { "const": "success" },
        "createdAtUtc": { "type": "string", "format": "date-time" },
        "startedAtUtc": { "type": "string", "format": "date-time" },
        "completedAtUtc": { "type": "string", "format": "date-time" }
      }
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "status", "conclusion", "startedAtUtc", "completedAtUtc"],
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9]+$" },
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "conclusion": { "type": ["string", "null"] },
          "startedAtUtc": { "type": ["string", "null"], "format": "date-time" },
          "completedAtUtc": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "sizeBytes", "expired"],
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9]+$" },
          "name": { "type": "string", "minLength": 1 },
          "sizeBytes": { "type": "integer", "minimum": 0 },
          "expired": { "type": "boolean" }
        }
      }
    }
  }
}
