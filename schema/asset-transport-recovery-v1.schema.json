{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/asset-transport-recovery/v1.json",
  "title": "Velox asset transport recovery result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "framework", "frameworkRevision", "profileControl", "sample", "scenario", "requestedDelayMs", "outcome", "startedAtUtc", "finishedAtUtc", "environment", "measurement", "failure"],
  "properties": {
    "schemaVersion": { "const": "velox.asset-transport-recovery/v1" },
    "suite": { "const": "asset-transport-recovery-boundary" },
    "framework": { "enum": ["velox", "fork-file-url", "fork-virtual-host"] },
    "frameworkRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "profileControl": { "const": "explicit-udf" },
    "sample": { "type": "integer", "minimum": 0, "maximum": 9 },
    "scenario": { "enum": ["velox-same-profile", "velox-fresh-profile", "file-url-same-profile", "file-url-fresh-profile", "virtual-host-same-profile", "virtual-host-fresh-profile", "virtual-host-fresh-origin"] },
    "requestedDelayMs": { "enum": [0, 1000, 2000, 4000, 6000, 7000] },
    "outcome": { "enum": ["success", "failure", "timeout"] },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture", "runnerImage", "runnerImageVersion", "webView2Version", "repositoryCommit", "runId", "runAttempt"],
      "properties": {
        "os": { "const": "windows" },
        "architecture": { "const": "amd64" },
        "runnerImage": { "type": "string", "minLength": 1 },
        "runnerImageVersion": { "type": "string", "minLength": 1 },
        "webView2Version": { "type": "string", "minLength": 1 },
        "repositoryCommit": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "runAttempt": { "type": "string", "minLength": 1 }
      }
    },
    "measurement": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyBoundary", "actualProcessStartAfterFirstHostExitMs", "browserExitObservationTimeoutMs", "firstBrowserRunningAtRelaunchStart", "browserProcessSharedAcrossPair", "first", "relaunched"],
          "properties": {
            "readyBoundary": { "const": "process-start-to-framework-ready-after-domcontentloaded-plus-two-animation-frames" },
            "actualProcessStartAfterFirstHostExitMs": { "type": "number", "minimum": 0 },
            "browserExitObservationTimeoutMs": { "const": 15000 },
            "firstBrowserRunningAtRelaunchStart": { "type": "boolean" },
            "browserProcessSharedAcrossPair": { "type": "boolean" },
            "first": { "$ref": "#/$defs/launch" },
            "relaunched": { "$ref": "#/$defs/launch" }
          }
        },
        { "type": "null" }
      ]
    },
    "failure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase", "code"],
          "properties": {
            "phase": { "type": "string", "minLength": 1 },
            "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
          }
        },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "elapsedMs"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "elapsedMs": { "type": "number", "minimum": 0 }
      }
    },
    "startupTimeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "clock", "phases"],
      "properties": {
        "schemaVersion": { "const": "velox.host-startup-timeline/v1" },
        "clock": { "const": "time-since-host-entry-monotonic" },
        "phases": { "type": "array", "minItems": 5, "items": { "$ref": "#/$defs/phase" } }
      }
    },
    "shutdownTimeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "clock", "phases"],
      "properties": {
        "schemaVersion": { "const": "velox.host-shutdown-timeline/v1" },
        "clock": { "const": "time-since-shutdown-request-monotonic" },
        "phases": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/phase" } }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readyMs", "hostExitMs", "hostProcessId", "browserProcessId", "browserExitAfterHostExitMs", "startupTimeline", "shutdownTimeline"],
      "properties": {
        "readyMs": { "type": "number", "minimum": 0 },
        "hostExitMs": { "type": "number", "minimum": 0 },
        "hostProcessId": { "type": "integer", "minimum": 1 },
        "browserProcessId": { "type": "integer", "minimum": 1 },
        "browserExitAfterHostExitMs": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "startupTimeline": { "$ref": "#/$defs/startupTimeline" },
        "shutdownTimeline": { "$ref": "#/$defs/shutdownTimeline" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": { "properties": { "measurement": { "type": "object" }, "failure": { "type": "null" } } },
      "else": { "properties": { "measurement": { "type": "null" }, "failure": { "type": "object" } } }
    }
  ]
}
