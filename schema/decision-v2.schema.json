{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/bench-decision/v2.json",
  "title": "Actutum benchmark go-or-kill decision v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "evidenceLevel", "status", "target", "metrics", "gates", "questionsRequired"],
  "properties": {
    "schemaVersion": { "const": "actutum.bench-decision/v2" },
    "suite": { "const": "zero-cache" },
    "evidenceLevel": { "enum": ["diagnostic", "publishable"] },
    "status": { "enum": ["promising", "below-target", "passed", "failed", "insufficient-evidence"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "minimum"],
      "properties": {
        "metric": { "const": "wails-to-actutum-p50-ratio" },
        "minimum": { "const": 3 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actutumP50Ms", "wailsP50Ms", "wailsToActutumP50Ratio"],
      "properties": {
        "actutumP50Ms": { "type": ["number", "null"], "minimum": 0 },
        "wailsP50Ms": { "type": ["number", "null"], "minimum": 0 },
        "wailsToActutumP50Ratio": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completeSuccessfulSamples", "singleEnvironment", "hardwareBalanced", "zeroCacheUpload", "minimumSpeedup"],
      "properties": {
        "completeSuccessfulSamples": { "type": "boolean" },
        "singleEnvironment": { "type": "boolean" },
        "hardwareBalanced": { "type": "boolean" },
        "zeroCacheUpload": { "type": "boolean" },
        "minimumSpeedup": { "type": ["boolean", "null"] }
      }
    },
    "questionsRequired": { "type": "boolean" }
  }
}
