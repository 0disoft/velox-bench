{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0disoft.dev/actutum/recommended-cache-result-v2.schema.json",
  "title": "Actutum recommended-cache phase result v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "phase", "framework", "frameworkRevision", "sample", "fixture", "outcome", "startedAtUtc", "finishedAtUtc", "environment", "cache", "measurement", "failure"],
  "properties": {
    "schemaVersion": { "const": "actutum.recommended-cache-result/v2" },
    "suite": { "const": "recommended-cache" },
    "phase": { "enum": ["prime", "warm"] },
    "framework": { "enum": ["actutum", "wails", "neutralino", "tauri"] },
    "frameworkRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sample": { "type": "integer", "minimum": 0, "maximum": 2 },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "generatedFiles", "generatedBytes"],
      "properties": {
        "name": { "const": "hello" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "generatedFiles": { "const": 0 },
        "generatedBytes": { "const": 0 }
      }
    },
    "outcome": { "enum": ["success", "failure", "timeout"] },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "runnerImageVersion", "os", "architecture", "windowsVersion", "cpuModel", "logicalProcessors", "memoryBytes", "bunVersion", "repositoryCommit", "runId", "runAttempt"],
      "properties": {
        "runner": { "const": "windows-2025" },
        "runnerImageVersion": { "type": "string", "minLength": 1 },
        "os": { "const": "windows" },
        "architecture": { "const": "amd64" },
        "windowsVersion": { "type": "string", "minLength": 1 },
        "cpuModel": { "type": "string", "minLength": 1 },
        "logicalProcessors": { "type": "integer", "minimum": 1 },
        "memoryBytes": { "type": "integer", "minimum": 1 },
        "bunVersion": { "const": "1.3.14" },
        "repositoryCommit": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "runAttempt": { "type": "string", "minLength": 1 }
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "paths", "key", "restoreHit", "restoreMs", "saveMs", "archiveBytes", "uploadedCacheBytes", "restoredCacheBytes", "evidence"],
      "properties": {
        "policy": { "enum": ["none", "go-module-build", "npm-download", "cargo-registry-target"] },
        "paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "key": { "type": ["string", "null"] },
        "restoreHit": { "type": ["boolean", "null"] },
        "restoreMs": { "type": "number", "minimum": 0 },
        "saveMs": { "type": "number", "minimum": 0 },
        "archiveBytes": { "type": "integer", "minimum": 0 },
        "uploadedCacheBytes": { "type": "integer", "minimum": 0 },
        "restoredCacheBytes": { "type": "integer", "minimum": 0 },
        "evidence": { "enum": ["github-actions-api", "workflow-action-output", "not-applicable"] }
      }
    },
    "measurement": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["endToEndMs", "frameworkSetupMs", "buildMs", "packageMs", "cacheWorkingSetFiles", "cacheWorkingSetBytes", "outputFiles", "outputBytes", "outputArchiveBytes", "outputArchiveSha256", "intermediateFiles", "intermediateBytes"],
          "properties": {
            "endToEndMs": { "type": "number", "minimum": 0 },
            "frameworkSetupMs": { "type": "number", "minimum": 0 },
            "buildMs": { "type": "number", "minimum": 0 },
            "packageMs": { "type": "number", "minimum": 0 },
            "cacheWorkingSetFiles": { "type": "integer", "minimum": 0 },
            "cacheWorkingSetBytes": { "type": "integer", "minimum": 0 },
            "outputFiles": { "type": "integer", "minimum": 0 },
            "outputBytes": { "type": "integer", "minimum": 0 },
            "outputArchiveBytes": { "type": "integer", "minimum": 0 },
            "outputArchiveSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "intermediateFiles": { "type": "integer", "minimum": 0 },
            "intermediateBytes": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "failure": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase", "code"],
          "properties": {
            "phase": { "type": "string", "minLength": 1 },
            "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": { "properties": { "measurement": { "type": "object" }, "failure": { "type": "null" } } },
      "else": { "properties": { "measurement": { "type": "null" }, "failure": { "type": "object" } } }
    }
  ]
}
